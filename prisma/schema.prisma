generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum ExpenseType {
  OPERATIONAL
  STOCK
  OTHER
}

enum PaymentMethod {
  CASH
  QRIS
  DEBIT
  TRANSFER
  E_WALLET
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

model Outlet {
  id          String   @id @default(uuid())

  name        String
  address     String?
  noTelp      String?

  qrisImage   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  products    Product[]
  sales       Sale[]
  expenses    Expense[]
}

model User {
  id              String   @id @default(uuid())

  name            String
  email           String   @unique
  password        String

  role            Role @default(ADMIN)

  resetToken      String?
  resetTokenExp   DateTime?

  outletId        String?

  outlet          Outlet? @relation(fields: [outletId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sales           Sale[]
}

model Category {
  id          String   @id @default(uuid())

  name        String   @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
}

model Product {
  id            String   @id @default(uuid())

  name          String

  sku           String? @unique
  barcode       String? @unique

  stock         Int @default(0)
  minStock      Int @default(5)

  costPrice     Float
  sellingPrice  Float

  imageUrl      String?

  categoryId    String?

  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  outletId      String

  outlet        Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  saleItems     SaleItem[]
}

model Sale {
  id               String @id @default(uuid())

  invoiceNumber    String @unique

  totalAmount      Float
  totalProfit      Float

  paymentMethod    PaymentMethod
  paymentStatus    PaymentStatus @default(PENDING)

  paidAmount       Float?
  changeAmount     Float?

  paymentProof     String?

  outletId         String

  outlet           Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  cashierId        String

  cashier          User @relation(fields: [cashierId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            SaleItem[]
}

model SaleItem {
  id            String @id @default(uuid())

  saleId        String

  sale          Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId     String

  product       Product @relation(fields: [productId], references: [id], onDelete: NoAction)

  quantity      Int

  costPrice     Float
  sellingPrice  Float

  subtotal      Float
  profit        Float

  createdAt     DateTime @default(now())
}

model Expense {
  id            String @id @default(uuid())

  title         String
  description   String?

  type          ExpenseType @default(OPERATIONAL)

  amount        Float

  outletId      String

  outlet        Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
}